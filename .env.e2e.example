# ─────────────────────────────────────────────────────────────────────────────
# E2E environment for the `app` container (docker-compose.e2e.yml).
# Copy to `.env.e2e` and fill in real Stripe TEST keys before running.
#   cp .env.e2e.example .env.e2e
# This file is injected as real env vars (compose `env_file`), so no .env is
# written inside the container.
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME="Payment E2E"
APP_ENV=e2e
APP_DEBUG=true
# Fixed key so the container boots without `key:generate` (E2E only — not secret).
APP_KEY=base64:1L4Nh+2IvRuLMdL47lDFXDxtDEiNPsOycOSn0/X7z2o=

# success_url / cancel_url must point back at the app inside the docker network,
# so the browser (playwright container) can follow Stripe's redirect.
APP_URL=http://app:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite

# Real worker processes the forwarded webhooks (ProcessStripeEvent).
QUEUE_CONNECTION=database
SESSION_DRIVER=database
CACHE_STORE=database
MAIL_MAILER=log

BCRYPT_ROUNDS=4

# ── Stripe TEST mode ─────────────────────────────────────────────────────────
# Use test keys (pk_test_..., sk_test_...). STRIPE_SECRET is also read by the
# stripe-cli container to run `stripe listen`.
STRIPE_KEY=pk_test_xxx
STRIPE_SECRET=sk_test_xxx
# STRIPE_WEBHOOK_SECRET is intentionally left UNSET here. The entrypoint exports
# it from `stripe listen --print-secret` (shared volume). Do not set it here, or
# Laravel's immutable dotenv would pin the wrong value.

# 'card' for the happy-path / failed tests. Set 'card,konbini' for the Konbini
# test (Konbini must be enabled in the Stripe Dashboard for the test account).
STRIPE_PAYMENT_METHODS=card

CHECKOUT_TTL_CARD_MINUTES=15
CHECKOUT_TTL_ASYNC_DAYS=3
RECONCILE_STUCK_AFTER_MINUTES=30
