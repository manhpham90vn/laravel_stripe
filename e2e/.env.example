# Optional env for running Playwright OUTSIDE docker (against a host app).
# Inside docker these are provided by compose (BASE_URL, STRIPE_SECRET).
BASE_URL=http://localhost:8000

# Seeded demo accounts (DatabaseSeeder) — password is "password".
E2E_BUYER_EMAIL=test@example.com
E2E_ADMIN_EMAIL=admin@example.com
E2E_PASSWORD=password

# Needed only for the Konbini/failed tests that use `stripe trigger`.
STRIPE_SECRET=sk_test_xxx
